# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — it will never be committed.

# Anthropic Claude API
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Default model
ANTHROPIC_MODEL=claude-sonnet-4-6

# Messaging provider: "mock" (no real send) | "aligo" | "mp-interactive"
MESSAGING_PROVIDER=mock

# Aligo (only required when MESSAGING_PROVIDER=aligo)
# ALIGO_API_KEY=
# ALIGO_USER_ID=
# ALIGO_SENDER_KEY=
